# 遇见路得后端环境变量示例 — 复制为 .env 并填入真实值
# 切勿把真实 .env 提交到 git

# PostgreSQL 连接串
DATABASE_URL=postgres://edu_admin:password@localhost:5432/yujian_lude

# 服务端口
PORT=8090

# session cookie 签名密钥（生产环境务必改成长随机串）
SESSION_SECRET=change-this-to-a-long-random-string

# session 有效期（天）
SESSION_TTL_DAYS=30

# 运行环境 development / production
NODE_ENV=development

# 是否在跨域 https 下启用 secure cookie（生产置 true）
COOKIE_SECURE=false

# 上线前本地体检临时服务起始端口；可选，默认 8092
RELEASE_VERIFY_PORT=8092
